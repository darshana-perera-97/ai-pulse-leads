PORT=369
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Serper Google Places API — https://serper.dev (never commit real keys)
SERPER_API_KEY=

# Max Serper pages per search (1–100, default 40). Stops earlier when a page has no places.
SERPER_PLACES_MAX_PAGES=40

# Terminal HTTP request log: 1 (default, skips /whatsapp/status + /health), all, or 0=off
# BACKEND_HTTP_LOG=all
# Override quiet paths (comma-separated):
# BACKEND_HTTP_LOG_QUIET_PATHS=/whatsapp/status,/health
